# linux-signed-* source packages are generated by the linux source
# package, so it is OK for their binaries to share documentation
linux-image-7.0.13+deb14-powerpc64le-64k: usr-share-doc-symlink-to-foreign-package linux-base-7.0.13+deb14-powerpc64le-64k

# linux-image-* only includes maintainer scripts
linux-image-7.0.13+deb14-powerpc64le-64k: empty-binary-package
