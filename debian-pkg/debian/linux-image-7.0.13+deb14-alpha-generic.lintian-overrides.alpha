# linux-signed-* source packages are generated by the linux source
# package, so it is OK for their binaries to share documentation
linux-image-7.0.13+deb14-alpha-generic: usr-share-doc-symlink-to-foreign-package linux-base-7.0.13+deb14-alpha-generic

# linux-image-* only includes maintainer scripts
linux-image-7.0.13+deb14-alpha-generic: empty-binary-package
